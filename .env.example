DATABASE_URL=postgresql://user:password@host/db?sslmode=require
# GitHub Actions production migration secret:
# PRODUCTION_DATABASE_URL=postgresql://user:password@host/db?sslmode=require
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_PROJECT_TOKEN=
SESSION_SECRET=replace-with-random-secret
ADMIN_GITHUB_LOGINS=tashua314
# 32-byte key in Base64. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PAYOUT_ACCOUNT_ENCRYPTION_KEY=
